{
  "name": "taif-school-system",
  "version": "1.0.0",
  "description": "Taif High School Management System",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "node src/server.js",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.rahimitech.taifschool",
    "productName": "Taif School System",
    "win": {
      "target": "nsis",
      "icon": "public/admin/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "qrcode": "^1.5.3",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  }
}